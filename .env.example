AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_KEY
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password
NEO4J_DATABASE=neo4j

CHROMA_HOST=chroma
CHROMA_URL=http://chroma:8000
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

RUNS_DIR=/data/runs

A2A_USER_AGENT_URL=http://user-agent:8001
A2A_ORCHESTRATOR_URL=http://orchestrator-agent:8002
A2A_GRAPHDB_AGENT_URL=http://graphdb-agent:8003
A2A_VECTOR_AGENT_URL=http://vector-agent:8004
A2A_INGEST_AGENT_URL=http://ingest-agent:8005
A2A_DATASET_AGENT_URL=http://dataset-agent:8006
A2A_MATCHING_AGENT_URL=http://matching-agent:8007

LOG_LEVEL=INFO
ENV=dev
